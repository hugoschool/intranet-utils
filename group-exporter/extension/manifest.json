{
    "manifest_version": 3,
    "name": "group-exporter",
    "version": "0.0.1",
    "description": "Pull all the groups from all projects",
    "icons": {},
    "content_scripts": [
        {
            "matches": ["https://intra.epitech.eu/*"],
            "js": ["project-group.js"],
            "run_at": "document_end"
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "no-contact@nothing.nonexistant",
            "data_collection_permissions": {
                "required": ["websiteContent"],
                "optional": []
            }
        }
    }
}
